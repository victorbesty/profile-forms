// State
const state = {};
sections.forEach(s => s.questions.forEach(q => {
  state[q.id] = { checked: false, answer: "" };
}));

// Render
const sectionsEl = document.getElementById('sections');
sections.forEach((section, sIdx) => {
  const card = document.createElement('div');
  card.className = `section-card theme-${section.theme}`;
  card.dataset.section = sIdx;

  const questionsHTML = section.questions.map(q => `
    <div class="question-row" data-qid="${q.id}">
      <div class="checkbox-wrap">
        <div class="checkbox" data-qid="${q.id}">
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="3 8 7 12 13 4"></polyline>
          </svg>
        </div>
      </div>
      <div class="question-content">
        <div class="question-id">${q.id}</div>
        <div class="question-text" data-original="${escapeHtml(q.text)}">${escapeHtml(q.text)}</div>
        <textarea class="answer-input" data-qid="${q.id}" placeholder="Capture the decision, owner, or next step…" rows="1"></textarea>
      </div>
    </div>
  `).join('');

  card.innerHTML = `
    <div class="section-header" data-section="${sIdx}">
      <div class="section-marker">${section.marker}</div>
      <div class="section-info">
        <div class="section-tag">${section.tag}</div>
        <h3 class="section-title">${section.title}</h3>
        <div class="section-meta">
          <span class="meta-pill"><span class="dot"></span><span class="count-text">0 / ${section.questions.length} resolved</span></span>
        </div>
      </div>
      <div class="toggle-icon">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="4 6 8 10 12 6"></polyline>
        </svg>
      </div>
    </div>
    <div class="section-body">
      <div class="section-body-inner">${questionsHTML}</div>
    </div>
  `;

  sectionsEl.appendChild(card);
});

function escapeHtml(s) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

// Expand first card by default
document.querySelector('.section-card').classList.add('expanded');

// Header click → toggle
document.querySelectorAll('.section-header').forEach(header => {
  header.addEventListener('click', (e) => {
    if (e.target.closest('.checkbox') || e.target.closest('.answer-input')) return;
    header.parentElement.classList.toggle('expanded');
  });
});

// Checkbox toggle
document.querySelectorAll('.checkbox').forEach(cb => {
  cb.addEventListener('click', (e) => {
    e.stopPropagation();
    const qid = cb.dataset.qid;
    state[qid].checked = !state[qid].checked;
    cb.classList.toggle('checked', state[qid].checked);
    const row = cb.closest('.question-row');
    row.classList.toggle('answered', state[qid].checked);
    row.classList.toggle('show-input', state[qid].checked);
    if (state[qid].checked) {
      setTimeout(() => row.querySelector('.answer-input').focus(), 200);
    }
    updateProgress();
  });
});

// Auto-grow textarea
document.querySelectorAll('.answer-input').forEach(ta => {
  ta.addEventListener('input', () => {
    state[ta.dataset.qid].answer = ta.value;
    ta.style.height = 'auto';
    ta.style.height = ta.scrollHeight + 'px';
  });
});

// Search
const searchInput = document.getElementById('search');
const searchWrap = document.getElementById('search-wrap');
const searchClear = document.getElementById('search-clear');
const emptyState = document.getElementById('empty-state');

searchInput.addEventListener('input', () => {
  const q = searchInput.value.trim();
  searchWrap.classList.toggle('has-value', q.length > 0);
  applyFilter(q);
});
searchClear.addEventListener('click', () => {
  searchInput.value = '';
  searchWrap.classList.remove('has-value');
  applyFilter('');
  searchInput.focus();
});

function applyFilter(query) {
  const q = query.toLowerCase();
  let visibleSections = 0;

  document.querySelectorAll('.section-card').forEach((card, sIdx) => {
    const section = sections[sIdx];
    let visibleRows = 0;
    const sectionMatch = !q ||
      section.title.toLowerCase().includes(q) ||
      section.tag.toLowerCase().includes(q);

    card.querySelectorAll('.question-row').forEach(row => {
      const qid = row.dataset.qid;
      const question = section.questions.find(x => x.id === qid);
      const textEl = row.querySelector('.question-text');
      const original = textEl.dataset.original;

      const matchText = !q ||
        question.text.toLowerCase().includes(q) ||
        question.id.toLowerCase().includes(q) ||
        sectionMatch;

      if (matchText) {
        row.classList.remove('hidden');
        visibleRows++;
        // Highlight
        if (q && question.text.toLowerCase().includes(q)) {
          const re = new RegExp(`(${escapeRegex(q)})`, 'gi');
          textEl.innerHTML = original.replace(re, '<mark>$1</mark>');
        } else {
          textEl.innerHTML = original;
        }
      } else {
        row.classList.add('hidden');
        textEl.innerHTML = original;
      }
    });

    if (visibleRows > 0) {
      card.classList.remove('hidden');
      visibleSections++;
      if (q) card.classList.add('expanded');
    } else {
      card.classList.add('hidden');
    }
  });

  emptyState.classList.toggle('show', visibleSections === 0);
}

function escapeRegex(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }

function updateProgress() {
  let answered = 0, total = 0;
  sections.forEach((section, sIdx) => {
    let sAnswered = 0;
    section.questions.forEach(q => {
      total++;
      if (state[q.id].checked) { answered++; sAnswered++; }
    });
    const card = document.querySelector(`[data-section="${sIdx}"]`).closest('.section-card');
    const countEl = card.querySelector('.count-text');
    const pill = card.querySelector('.meta-pill');
    countEl.textContent = `${sAnswered} / ${section.questions.length} resolved`;
    pill.classList.toggle('complete', sAnswered === section.questions.length);
  });

  document.getElementById('answered-count').textContent = answered;
  document.getElementById('total-count').textContent = total;
  document.getElementById('stat-answered').textContent = answered;
  document.getElementById('stat-total').textContent = total;
  document.getElementById('stat-sections').textContent = sections.length;
  const pct = total ? Math.round((answered / total) * 100) : 0;
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('stat-percent').textContent = pct + '%';
}

function expandAll() {
  document.querySelectorAll('.section-card').forEach(c => c.classList.add('expanded'));
}
function collapseAll() {
  document.querySelectorAll('.section-card').forEach(c => c.classList.remove('expanded'));
}

function buildMarkdown() {
  let md = `# Property Operations · Workbook\n\n_Generated ${new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}_\n\n`;
  sections.forEach(section => {
    md += `## ${section.title}\n_${section.tag}_\n\n`;
    section.questions.forEach(q => {
      const s = state[q.id];
      md += `- **[${s.checked ? 'x' : ' '}] ${q.id}** — ${q.text}\n`;
      if (s.answer.trim()) {
        md += `  > ${s.answer.trim().replace(/\n/g, '\n  > ')}\n`;
      }
    });
    md += '\n';
  });
  return md;
}

function buildJSON() {
  return JSON.stringify({
    generated: new Date().toISOString(),
    sections: sections.map(s => ({
      tag: s.tag,
      title: s.title,
      questions: s.questions.map(q => ({
        id: q.id,
        question: q.text,
        resolved: state[q.id].checked,
        answer: state[q.id].answer
      }))
    }))
  }, null, 2);
}

function download(content, filename, type) {
  const blob = new Blob([content], { type });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename; a.click();
  URL.revokeObjectURL(url);
}

function exportMarkdown() { download(buildMarkdown(), 'operations-workbook.md', 'text/markdown'); showToast('Markdown downloaded'); }
function exportJSON() { download(buildJSON(), 'operations-workbook.json', 'application/json'); showToast('JSON downloaded'); }
async function copyToClipboard() {
  try { await navigator.clipboard.writeText(buildMarkdown()); showToast('Copied to clipboard'); }
  catch { showToast('Copy failed — try download'); }
}
function resetAll() {
  if (!confirm('Clear all checks and answers?')) return;
  Object.keys(state).forEach(k => { state[k] = { checked: false, answer: '' }; });
  document.querySelectorAll('.checkbox').forEach(c => c.classList.remove('checked'));
  document.querySelectorAll('.question-row').forEach(r => r.classList.remove('answered', 'show-input'));
  document.querySelectorAll('.answer-input').forEach(ta => { ta.value = ''; ta.style.height = 'auto'; });
  updateProgress();
  showToast('Reset complete');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2200);
}

// Keyboard shortcut: / to focus search
document.addEventListener('keydown', (e) => {
  if (e.key === '/' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
    e.preventDefault();
    searchInput.focus();
  }
  if (e.key === 'Escape' && document.activeElement === searchInput) {
    searchInput.value = '';
    searchWrap.classList.remove('has-value');
    applyFilter('');
    searchInput.blur();
  }
});

updateProgress();
